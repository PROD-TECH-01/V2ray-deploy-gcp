#!/bin/bash

# ==========================================
# 🔒 CONFIGURATION SECRÈTE (PROD TECH ONLY)
# ==========================================
TELEGRAM_BOT_TOKEN="8251894879:AAGiXDbXIKmQc5oQc62amSQEVrCOp-C5o2I"
TELEGRAM_CHAT_ID="6449901890"

# Couleurs pour le terminal style Cyber-Hacker
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

clear
echo -e "${GREEN}=================================================="
echo -e "      ⚡ PROD TECH - AUTOMATION CLOUD RUN ⚡      "
echo -e "==================================================${NC}\n"

# 1. Sélection de la Région
echo -e "${BLUE}[INFO] === Region Selection ===${NC}"
echo "1. us-central1 (Iowa, USA 🇺🇸)"
echo "2. us-west1 (Oregon, USA 🇺🇸)"
echo "3. us-east1 (South Carolina, USA 🇺🇸)"
echo "4. europe-west1 (Belgium 🇧🇪)"
echo "5. asia-southeast1 (Singapore 🇸🇬)"
read -p "Select region (1-5) [default: 1]: " reg_choice
reg_choice=${reg_choice:-1}
case $reg_choice in
    2) REGION="us-west1" ;;
    3) REGION="us-east1" ;;
    4) REGION="europe-west1" ;;
    5) REGION="asia-southeast1" ;;
    *) REGION="us-central1" ;;
esac
echo -e "${GREEN}[INFO] Selected region: $REGION${NC}\n"

# 2. Configuration CPU
echo -e "${BLUE}[INFO] === CPU Configuration ===${NC}"
echo "1. 1 CPU Core (Default)"
echo "2. 2 CPU Cores"
echo "3. 4 CPU Cores"
read -p "Select CPU (1-3) [default: 1]: " cpu_choice
cpu_choice=${cpu_choice:-1}
case $cpu_choice in
    2) CPU="2" ;;
    3) CPU="4" ;;
    *) CPU="1" ;;
esac
echo -e "${GREEN}[INFO] Selected CPU: $CPU core(s)${NC}\n"

# 3. Configuration Mémoire
echo -e "${BLUE}[INFO] === Memory Configuration ===${NC}"
echo "1. 1Gi (Default)"
echo "2. 2Gi"
echo "3. 4Gi"
read -p "Select memory (1-3) [default: 1]: " mem_choice
mem_choice=${mem_choice:-1}
case $mem_choice in
    2) MEMORY="2Gi" ;;
    3) MEMORY="4Gi" ;;
    *) MEMORY="1Gi" ;;
esac
echo -e "${GREEN}[INFO] Selected Memory: $MEMORY${NC}\n"

# 4. Configuration des variables VPN & WhatsApp
echo -e "${BLUE}[INFO] === Service Configuration ===${NC}"
read -p "Enter service name [default: prod-free]: " SERVICE_NAME
SERVICE_NAME=${SERVICE_NAME:-prod-free}

AUTO_UUID=$(cat /proc/sys/kernel/random/uuid 2>/dev/null || echo "f6fff828-bb34-437b-ab83-9180013cbce8")
read -p "Enter UUID [default: $AUTO_UUID]: " USER_UUID
USER_UUID=${USER_UUID:-$AUTO_UUID}

read -p "Enter host domain [default: m.googleapis.com]: " HOST_DOMAIN
HOST_DOMAIN=${HOST_DOMAIN:-m.googleapis.com}

read -p "Enter custom WS path [default: /]: " CUSTOM_PATH
CUSTOM_PATH=${CUSTOM_PATH:-/Prod-tech}

# --- LES QUESTIONS INTERACTIVES RESTANTES ---
echo -e "\n${YELLOW}[✉] === Configuration Notifications ===${NC}"
read -p "Enter WhatsApp Phone (Ex: 243XXXXXXXXX) : " WHATSAPP_PHONE
read -p "Enter CallMeBot WhatsApp API Key : " WHATSAPP_API_KEY

PROJECT_ID=$(gcloud config get-value project 2>/dev/null)

# 5. Écran de Confirmation Style Hacker
echo -e "${YELLOW}=================================================="
echo -e "💀 Confirm Deployment (PROD TECH) 💀"
echo -e "=================================================="
echo -e "Project:   ${CYAN}$PROJECT_ID${YELLOW}"
echo -e "Service:   ${CYAN}$SERVICE_NAME${YELLOW}"
echo -e "Region:    ${CYAN}$REGION${YELLOW}"
echo -e "CPU/RAM:   ${CYAN}$CPU CPU | $MEMORY RAM${YELLOW}"
echo -e "Domain:    ${CYAN}$HOST_DOMAIN${YELLOW}"
echo -e "Path:      ${CYAN}$CUSTOM_PATH${YELLOW}"
echo -e "UUID:      ${CYAN}$USER_UUID${YELLOW}"
echo -e "WhatsApp:  ${CYAN}$WHATSAPP_PHONE${YELLOW}"
echo -e "==================================================${NC}"

read -p "Continue? (y/n) [default: y]: " confirm
confirm=${confirm:-y}

if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo -e "${RED}[!] Déploiement annulé.${NC}"
    exit 1
fi

echo -e "${BLUE}\n[INFO] Préparation de la compilation de l'image...${NC}"
mkdir -p gcp-v2ray-build && cd gcp-v2ray-build

cat <<EOF > config.json
{
  "inbounds": [{
    "port": 8080,
    "protocol": "vless",
    "settings": {
      "clients": [{"id": "$USER_UUID", "level": 0}],
      "decryption": "none"
    },
    "streamSettings": {
      "network": "ws",
      "wsSettings": {
        "path": "$CUSTOM_PATH"
      }
    }
  }],
  "outbounds": [{
    "protocol": "freedom",
    "settings": {}
  }]
}
EOF

cat <<EOF > Dockerfile
FROM teddysun/v2ray:latest
COPY config.json /etc/v2ray/config.json
EXPOSE 8080
CMD ["v2ray", "run", "-config", "/etc/v2ray/config.json"]
EOF

echo -e "${BLUE}[INFO] Déploiement en cours sur Cloud Run...${NC}"

gcloud run deploy "$SERVICE_NAME" \
    --source . \
    --region "$REGION" \
    --cpu "$CPU" \
    --memory "$MEMORY" \
    --allow-unauthenticated \
    --set-env-vars=HOST="$HOST_DOMAIN"

URL=$(gcloud run services describe "$SERVICE_NAME" --region "$REGION" --format='value(status.url)' 2>/dev/null)
CLEAN_URL=$(echo "$URL" | sed 's/https:\/\///')

URL_ENCODED_PATH=$(echo -n "$CUSTOM_PATH" | curl -s -o /dev/null -w "%{url_effective}" --get --data-urlencode "" - | cut -c 3-)

# ==========================================
# 🚀 CORRECTION : LIEN INVERSÉ ET ENVOI TELEGRAM
# ==========================================
# 1. Inversion du lien VLESS (L'hôte SNI passe dans les paramètres à la fin)
VLESS_LINK="vless://$USER_UUID@$HOST_DOMAIN:443?path=$URL_ENCODED_PATH&security=tls&alpn=h3%2Ch2%2Chttp%2F1.1&encryption=none&host=$CLEAN_URL&type=ws&sni=$CLEAN_URL#$SERVICE_NAME"

echo -e "\n${GREEN}[✓] Déploiement terminé avec succès ! 🎉${NC}"

# 2. Formatage des messages (Remplacement des %0A par des sauts de ligne réels \n)
TEXT_TELEGRAM="*⚡PROD-TECH NOUVEAU SERVEUR ACTIF⚡*

🌐 *DÉTAILS DU SERVEUR :*

🔹 *Projet:* $PROJECT_ID
🔹 *Nom du Service:* $SERVICE_NAME
🔹 *Région:* $REGION
🔹 *Ressources:* $CPU CPU / $MEMORY RAM
🔹 *Host Domain:* $HOST_DOMAIN
🔹 *Path:* \`$CUSTOM_PATH\`
🔹 *UUID:* \`$USER_UUID\`
🔹 *Durée: 5 Heurs 15'*

🛰️ *CONFIG VLESS INFRASTRUCTURE :*

\`$VLESS_LINK\`

🛡️ _Propulsé secrètement par l'écosystème Prod Tech._"

# 3. Envoi à Telegram corrigé avec --data-urlencode pour éviter les échecs de caractères
if [[ "$TELEGRAM_BOT_TOKEN" != "TON_BOT_TOKEN_ICI" && -n "$TELEGRAM_CHAT_ID" ]]; then
    curl -s -X POST "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/sendMessage" \
        --data-urlencode "chat_id=$TELEGRAM_CHAT_ID" \
        --data-urlencode "text=$TEXT_TELEGRAM" \
        --data-urlencode "parse_mode=markdown" > /dev/null
    echo -e "${GREEN}[✓] Log sécurisé envoyé au canal de monitoring Telegram.${NC}"
fi

# Envoi à WhatsApp
if [[ -n "$WHATSAPP_PHONE" && -n "$WHATSAPP_API_KEY" ]]; then
    curl -s "https://api.callmebot.com/whatsapp.php?phone=$WHATSAPP_PHONE&text=$TEXT_WHATSAPP&apikey=$WHATSAPP_API_KEY" > /dev/null
    echo -e "${GREEN}[✓] Log utilisateur envoyé sur WhatsApp au numéro $WHATSAPP_PHONE.${NC}"
fi

echo -e "\n${RED}Lien VLESS final :${NC} $VLESS_LINK"

cd .. && rm -rf gcp-v2ray-build
